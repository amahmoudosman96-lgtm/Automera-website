# ─── Zoho Mail SMTP ───────────────────────────────────────────
# Generate an App Password at: Zoho Account → Security → App Passwords
# Use port 465 (SSL) — NOT 587 (STARTTLS requires secure: false + starttls)
ZOHO_SMTP_HOST=smtp.zoho.com
ZOHO_SMTP_PORT=465
ZOHO_SMTP_USER=hello@automera.co
ZOHO_SMTP_PASS=your-zoho-app-password
ZOHO_SMTP_FROM=hello@automera.co

# The email address that receives contact form submissions
CONTACT_TO_EMAIL=ali@automera.co

# ─── Cal.com ──────────────────────────────────────────────────
# Your Cal.com username (the part after cal.com/)
NEXT_PUBLIC_CAL_LINK=automera
